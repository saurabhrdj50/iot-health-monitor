# Backend configuration
# Copy this file to .env and adjust values for your environment

# Host binding: use 0.0.0.0 for port forwarding / remote access
IHM_HOST=0.0.0.0

# Port
IHM_PORT=8000

# CORS allowed origins (comma-separated)
# Local dev:
IHM_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Remote / forwarded (add your forwarded URL):
# IHM_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-forwarded-url.app

# Allow all origins (dev only — never use in production)
# Set to "true" to disable origin filtering entirely
IHM_ALLOW_ALL_ORIGINS=false

# Admin token for protected endpoints
IHM_ADMIN_TOKEN=change-me

# ThingSpeak channel URL
THINGSPEAK_URL=https://api.thingspeak.com/channels/3144180/feeds.json?results=1
